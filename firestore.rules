rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "fahmi.imamuddin44@guru.smp.belajar.id" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'name', 'role', 'createdAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['name', 'category', 'price', 'rating', 'image', 'brand', 'socket', 'memory', 'description', 'stock', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 150 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 500 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('stock' in data) || (data.stock is number && data.stock >= 0));
    }

    function isValidServiceTicket(data) {
      return hasOnlyAllowedFields(['ticketId', 'customer', 'phone', 'device', 'issue', 'date', 'serviceType', 'status', 'estimatedCost', 'updates', 'createdAt', 'finalCost', 'finalDetails']) &&
             data.ticketId is string && data.ticketId.size() > 0 && data.ticketId.size() < 50 &&
             data.customer is string && data.customer.size() > 0 && data.customer.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.device is string && data.device.size() > 0 && data.device.size() < 150 &&
             data.issue is string && data.issue.size() > 0 && data.issue.size() < 1000 &&
             data.status is number && data.status >= 0 && data.status <= 3 &&
             data.updates is list && data.updates.size() <= 100 &&
             (!('finalCost' in data) || (data.finalCost is number && data.finalCost >= 0)) &&
             (!('finalDetails' in data) || (data.finalDetails is string && data.finalDetails.size() <= 2000));
    }

    function isValidService(data) {
      return hasOnlyAllowedFields(['title', 'description', 'price', 'iconId', 'color', 'bg', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.iconId is string && data.iconId.size() > 0 && data.iconId.size() < 50 &&
             data.color is string && data.color.size() > 0 && data.color.size() < 50 &&
             data.bg is string && data.bg.size() > 0 && data.bg.size() < 50 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only admins can create admin roles, or the user is creating their own customer profile
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || (isOwner(userId) && request.resource.data.role == 'customer')
      );
      // Only admins can update roles
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable for catalog
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true; // Publicly readable for services page
      allow create, update: if isAdmin() && isValidService(request.resource.data);
      allow delete: if isAdmin();
    }

    match /service_tickets/{ticketId} {
      // Anyone can read if they know the ticketId (used for tracking)
      allow read: if true;
      // Anyone can create a ticket (booking form)
      allow create: if isValidServiceTicket(request.resource.data);
      // Only admins can update or delete tickets
      allow update: if isAdmin() && isValidServiceTicket(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /active_sessions/{sessionId} {
      allow read: if isAdmin();
      allow create, update: if true && hasOnlyAllowedFields(['lastSeen', 'userId', 'isAnonymous']) &&
                               request.resource.data.lastSeen is timestamp;
      allow delete: if true;
    }
  }
}
